# Altere o programa anterior para que mostre todas as tabuadas de 1 a 100. (ciclos for).


for numero in range(1, 101):
    print(f"\n{'='*40}")
    print(f"Tabuada do {numero}")
    print(f"{'='*40}")
    
    for i in range(1, 11):
        print(f"{numero:3} x {i:2} = {numero * i:4}")
    
    print()