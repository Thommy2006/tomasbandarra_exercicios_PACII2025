# Elabore um programa que escreva no ecrã todas as linhas de código ASCII(0 a 255) e o código correspondente. Dispor de 20 em 20 com a condição de continuação ou saída do programa.


for codigo in range(0, 256):
    
    if codigo <= 32 or codigo == 127:
        print(f"Código {codigo:3}")
    else:
        # Caracteres imprimíveis
        print(f"Código {codigo:3} = {chr(codigo)}")
    
    if (codigo + 1) % 20 == 0 and codigo < 255:
        resposta = input("Pressione ENTER para continuar ou 'sair' para sair: ")
        if resposta.lower() == 'sair':
            break
        print()