# Elabore um programa que leia uma entrada e diga quantos números perfeitos existem. Exemplo de numero perfeito em que somando todos os divisores ele da o numero inicial.
# 6=3+2+1 .


limite = int(input("Introduza um número para ver os perfeitos até ele: "))

print(f"\nNúmeros perfeitos {limite}:\n")

contador = 0

for num in range(2, limite + 1):
    soma = 0
    
    for i in range(1, num):
        if num % i == 0:
            soma = soma + i
    
    if soma == num:
        print(f"{num} é perfeito (", end="")
        
        for i in range(1, num):
            if num % i == 0:
                if i < num - 1:
                    print(f"{i} + ", end="")
                else:
                    print(f"{i}", end="")
        print(f" = {num})")
        
        contador = contador + 1
