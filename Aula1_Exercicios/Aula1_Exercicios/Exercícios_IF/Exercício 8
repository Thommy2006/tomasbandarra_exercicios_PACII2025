
notas = []

for i in range(10):
    nota = float(input(f"Introduza a nota do {i+1}º aluno: "))
    notas.append(nota)

# Calcular
soma = 0
for nota in notas:
    soma = soma + nota

media = soma / 10

# Média
contador = 0
for nota in notas:
    if nota >= media:
        contador = contador + 1

# Mostrar os resultados
print("\nMédia da turma: {:.1f}".format(media))
print("Alunos com nota igual ou acima da média:", contador)