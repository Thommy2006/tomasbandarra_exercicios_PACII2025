pares = 0
impares = 0


for i in range(10):
    numero = int(input(f"Introduza o {i+1}º número: "))
    
    # Verificar se é par ou ímpar
    if numero % 2 == 0:
        pares = pares + 1      # par
    else:
        impares = impares + 1  # ímpar

# Resultado
print(f"\nPares: {pares}")
print(f"Ímpares: {impares}")