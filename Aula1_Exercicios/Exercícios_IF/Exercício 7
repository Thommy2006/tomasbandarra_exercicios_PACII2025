# Calcular a Média de Notas com Pesos

nota = float(input("Introduza a nota da primeira prova: "))
nota1 = float(input("Introduza a nota da segunda prova: "))
nota2 = float(input("Introduza a nota da terceira prova: "))

m = (nota * 2 + nota1 * 3 + nota2 * 5) / 10

print("\nMédia: {:.1f}".format(m))

if m >= 6:
    print("Aprovado")
else:
    print("Reprovado")