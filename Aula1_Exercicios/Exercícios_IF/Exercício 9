# Exibir Nome do Mês

meses = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", 
         "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"]

mes = int(input("Introduza um número de 1 a 12: "))


if 1 <= mes <= 12:
    print(meses[mes-1])
else:
    print("Número inválido. Introduza um número de 1 a 12.")